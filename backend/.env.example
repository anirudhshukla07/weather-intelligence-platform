# Copy this file to `.env` and configure the natural-language map assistant.
#
#   cp .env.example .env
#
# ── Choose a provider (local Ollama only) ───────────────────────────
# "ollama-prompt" works with ANY local model (model outputs JSON actions).
# "ollama" uses Ollama's native tool API (llama3.2:1b/3b, qwen2.5, etc.).
ASSISTANT_PROVIDER=ollama-prompt

# ── Ollama (local LLM server) ───────────────────────────────────────
# Must be a tool-calling model. llama3.2:3b works well and is light;
# llama3.2:1b also supports tools. (llama3:8b and the vision models do
# NOT support Ollama tool-calling.)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Offline speech-to-text (local Whisper via faster-whisper) ───────
# Model: tiny(.en)/base(.en)/small(.en)/medium(.en)/large-v3/distil-large-v3/
# large-v3-turbo. ".en" variants are English-only and faster. "large-v3-turbo"
# is the best accuracy/speed mix on a good GPU (~0.1s/clip on an RTX 4500 Ada).
WHISPER_MODEL=large-v3-turbo
# Device: "cuda" (GPU) or "cpu". Compute: float16 (GPU) or int8 (CPU).
WHISPER_DEVICE=cuda
WHISPER_COMPUTE=float16
