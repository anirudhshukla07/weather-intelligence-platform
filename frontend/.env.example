# Copy to `.env` and adjust. Vite reads these at build / dev-start, so after
# changing any value, restart `npm run dev` (or rebuild).

# Backend API (FastAPI) base URL.
VITE_API_BASE=http://localhost:8000

# Online map tile providers ({s}/{z}/{x}/{y} placeholders required).
VITE_TILE_STREET_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_TILE_STREET_ATTRIBUTION=OpenStreetMap

VITE_TILE_SATELLITE_URL=https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}
VITE_TILE_SATELLITE_ATTRIBUTION=Tiles © Esri — Source: Esri, Maxar, Earthstar Geographics
